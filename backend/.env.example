PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173
MONGODB_URI=mongodb://127.0.0.1:27017/eventiq
REDIS_URL=redis://127.0.0.1:6379
JWT_ACCESS_SECRET=replace-with-a-32-character-access-secret
JWT_REFRESH_SECRET=replace-with-a-different-32-character-refresh-secret
BCRYPT_SALT_ROUNDS=12
ADMIN_NAME=Eventiq Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-an-8-to-72-byte-password
ACQUIREMOCK_URL=http://localhost:8000
ACQUIREMOCK_WEBHOOK_SECRET=your-secret-key
ACQUIREMOCK_WEBHOOK_URL=https://your-render-backend.com/payments/webhook
CLOUDINARY_CLOUD_NAME=cloudinary-cloud-name
CLOUDINARY_API_KEY=cloudinary-api-key
CLOUDINARY_API_SECRET=cloudinary-api-secret
QR_HMAC_SECRET=replace-with-a-32-character-qr-secret
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Eventiq <noreply@eventiq.app>
